{
  "world_model": "latent",
  "custom_world": {
    "mappings_file": "mappings_cf_friendly.json"
  },
  "latent_world": {
    "latent_dim": 3,
    "num_modes": 3,
    "drone_variance": 0.01,
    "target_variance": 0.01,
    "target_hp": 5.0,
    "center_mode": "one_hot"
  },
  "seed": 42,
  "world": {
    "size": [
      1000.0,
      1000.0
    ]
  },
  "environment": {
    "max_steps":250,
    "mode": "episodic",
    "episodic": {
      "num_episodes": 35
    },
    "continuous": {
      "logging_interval_steps": 500
    },
    "verbose": false
  },  
  "drones": {
    "count": 9,
    "weapon_distribution": {
      "_A": 0.33,
      "_B": 0.33,
      "_C": 0.33
    },
    "region": {
      "x_fraction": [
        0.35,
        0.65
      ],
      "y_fraction": [
        0.3,
        0.4
      ]
    },
    "min_distance_between_drones": 25.0
  },
  "targets": {
    "count": 36,
    "region": {
      "x_fraction": [
        0.1,
        0.9
      ],
      "y_fraction": [
        0.5,
        0.75
      ]
    },
    "class_distribution": {
      "A": 0.33,
      "B": 0.33,
      "C": 0.33
    },
    "min_distance_from_drones": 50.0,
    "min_distance_between_targets": 25.0
  },
  "policy": {
    "type": [
      "random",
      "max_damage_oracle",
      "matrix_factorization_cf"
    ],
    "all_types": [
      "max_damage_oracle",
      "random",
      "selfish_ep_greedy_cf",
      "coordinated_ep_greedy_cf",
      "matrix_factorization_cf"
    ],
    "allow_noop": false
  },
  "collaborative_filtering": {
    "reward_noise": 0.2,
    "enable_tsne_enrichment": true,
    "matrix_factorization_cf": {
      "latent_dim": 8,
      "learning_rate": 0.01,
      "lambda_reg": 0.02,
      "epsilon": 0.3,
      "epsilon_decay": 0.9995,
      "epsilon_min": 0.02,
      "selection_noise": 0.0,
      "anti_signal_weight": 1.0
    },    
    "selfish_ep_greedy_cf": {
      "latent_dim": 3,
      "learning_rate": 0.05,
      "epsilon": 0.3,
      "epsilon_decay": 0.995,
      "epsilon_min": 0.05,
      "social_trust_factor": 0,
      "divergence_threshold": 0.5,
      "confidence_threshold": 0.8,
      "social_reward_clip_min": -0.5,
      "max_episodes": 10
    },
    "ucb_cf": {
      "latent_dim": 2,
      "learning_rate": 0.01,
      "ucb_c": 0.5
    },
    "coordinated_ep_greedy_cf": {
      "latent_dim": 5,
      "learning_rate": 0.05,
      "epsilon": 0.3,
      "epsilon_decay": 0.99,
      "epsilon_min": 0.05,
      "social_trust_factor": 0.3,
      "divergence_threshold": 0.5,
      "confidence_threshold": 0.8,
      "social_reward_clip_min": -0.5,
      "max_episodes": 100
    }
  },
  "logging": {
    "output_dir": "logs/"
  }
}
